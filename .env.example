# Server
PORT=5000
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb://127.0.0.1:27017/styling_consult
# or a MongoDB Atlas URI: mongodb+srv://<user>:<pass>@cluster.mongodb.net/styling_consult

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Email (nodemailer - example uses Gmail app password, swap for SendGrid/SES in production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Styled by [Sister's Name] <no-reply@stylingbiz.com>"

# Payments
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Video consultation (Zoom Server-to-Server OAuth app)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# If Zoom credentials are left blank, the system falls back to a Google Meet
# placeholder link that the stylist can replace manually per booking.
